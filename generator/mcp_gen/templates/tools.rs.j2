use mcp_factory_core::{
    ExecutionKind{% if tools | selectattr('execution_kind', 'equalto', 'graphql') | list %}, GraphQLOperation{% endif %}{% if tools | selectattr('execution_kind', 'equalto', 'rest') | list %}, ParamBinding, ParamLocation, RestOperation{% endif %}, ToolHints, ToolSpec,
};
use serde_json::json;

pub fn build_tools() -> Vec<ToolSpec> {
    vec![
{% for tool in tools %}
        ToolSpec {
            name: {{ tool.name | tojson }}.to_string(),
            description: {{ tool.description | tojson }}.to_string(),
            input_schema: json!({{ tool.input_schema | tojson }}),
            execution: ExecutionKind::{% if tool.execution_kind == "rest" %}Rest(RestOperation {
                method: {{ tool.rest.method | tojson }}.to_string(),
                path_template: {{ tool.rest.path_template | tojson }}.to_string(),
                params: vec![
{% for param in tool.rest.params %}
                    ParamBinding {
                        name: {{ param.name | tojson }}.to_string(),
                        location: ParamLocation::{% if param.location == "path" %}Path{% elif param.location == "query" %}Query{% else %}Header{% endif %},
                    },
{% endfor %}
                ],
                body_fields: vec![
{% for field in tool.rest.body_fields %}
                    {{ field | tojson }}.to_string(),
{% endfor %}
                ],
                content_type: {% if tool.rest.content_type %}Some({{ tool.rest.content_type | tojson }}.to_string()){% else %}None{% endif %},
                raw_body: {% if tool.rest.raw_body %}true{% else %}false{% endif %},
            }){% else %}GraphQL(GraphQLOperation {
                document: {{ tool.graphql.document | tojson }}.to_string(),
                variable_bindings: vec![
{% for binding in tool.graphql.variable_bindings %}
                    {{ binding | tojson }}.to_string(),
{% endfor %}
                ],
            }){% endif %},
            hints: ToolHints {
                title: {% if tool.title %}Some({{ tool.title | tojson }}.to_string()){% else %}None{% endif %},
                output_schema: {% if tool.output_schema %}Some(json!({{ tool.output_schema | tojson }})){% else %}None{% endif %},
                read_only: {% if tool.read_only is not none %}Some({{ tool.read_only | tojson }}){% else %}None{% endif %},
                destructive: {% if tool.destructive is not none %}Some({{ tool.destructive | tojson }}){% else %}None{% endif %},
                idempotent: {% if tool.idempotent is not none %}Some({{ tool.idempotent | tojson }}){% else %}None{% endif %},
                open_world: {% if tool.open_world is not none %}Some({{ tool.open_world | tojson }}){% else %}None{% endif %},
            },
        },
{% endfor %}
    ]
}
